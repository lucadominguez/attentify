{
  "manifest_version": 3,
  "name": "Productivity Daemon — Element Blocker",
  "version": "0.5.1",
  "description": "Surgically remove addictive UI elements. Works standalone or enhanced by the Productivity Daemon desktop app.",
  "permissions": ["storage", "tabs", "webNavigation", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:*/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start",
    "all_frames": true
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Productivity Daemon"
  },
  "incognito": "split"
}
