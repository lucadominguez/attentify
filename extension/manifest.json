{
  "manifest_version": 3,
  "name": "Attentify Element Blocker",
  "version": "0.18.2",
  "description": "Surgically remove addictive UI elements, with AI that reads your browsing context. Works standalone or enhanced by the Attentify desktop app.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "tabs", "webNavigation", "scripting", "alarms", "sidePanel"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:*/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start",
    "all_frames": true
  }],
  "action": {
    "default_title": "Attentify (click to open panel)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "incognito": "split"
}
